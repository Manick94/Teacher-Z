# ── Teacher-Z environment configuration ──────────────────────────────────────
# Copy this file to .env and fill in the values.
# NEVER commit the real .env to version control.

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=Teacher-Z
ENV=development          # development | production

# ── Auth ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-64-char-hex-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./teacherz.db
# Production: postgresql+asyncpg://user:pass@host:5432/teacherz

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Data paths ────────────────────────────────────────────────────────────────
# Root directory that holds dataset folders. Relative to repo root.
DATA_DIR=./data
# Root directory for downloaded model weights.
MODEL_DIR=./models

# ── AI / LLM provider ────────────────────────────────────────────────────────
# Choices: "local_transformers" | "ollama" | "stub"
#   local_transformers  – uses transformers library (requires torch + GPU/CPU)
#   ollama              – calls a running Ollama instance at OLLAMA_BASE_URL
#   stub                – returns template content; no ML required (for demos)
LLM_PROVIDER=stub

# ── Image captioning provider ────────────────────────────────────────────────
# Choices: "blip" | "stub"
#   blip   – uses Salesforce/blip-image-captioning-base (requires transformers)
#   stub   – derives caption from filename (no ML required)
IMAGE_PROVIDER=stub

# ── Model identifiers ─────────────────────────────────────────────────────────
LLM_MODEL_NAME=TinyLlama/TinyLlama-1.1B-Chat-v1.0
IMAGE_MODEL_NAME=Salesforce/blip-image-captioning-base

# ── Ollama (only used when LLM_PROVIDER=ollama) ───────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=tinyllama

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
